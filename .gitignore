# Rust
/target
**/*.rs.bk

# Node / frontend
node_modules/
apps/desktop/dist/

# Tauri generated
apps/desktop/src-tauri/gen/

# Local vault data / secrets (never commit)
*.vault
*.vault.tmp.*

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Pinned-extension keypair (public key lives in manifest.json; private key is
# only needed to pack a .crx and must never be committed)
extension/.ext-private-key.pem
extension/.ext-public-key.b64
extension/.ext-id.txt
